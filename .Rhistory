model       = model,
norm_params = list(mean = global_mean, sd = global_sd),
input_dim   = input_dim,
train_loss  = train_loss_history[1:epoch],
val_loss    = val_loss_history[1:epoch],
best_epoch  = best_epoch,
val_idx     = val_idx,      # validation index 보존
train_idx   = train_idx
))
}
compute_recon_error_v2 <- function(model, block_matrices_array, norm_params) {
model$eval()
n <- dim(block_matrices_array)[1]
vec_list <- lapply(1:n, function(i) {
upper_tri_vec(block_matrices_array[i, , ])
})
vec_mat <- do.call(rbind, vec_list)
vec_norm <- (vec_mat - norm_params$mean) / norm_params$sd
data_tensor <- torch_tensor(vec_norm)
with_no_grad({
output <- model(data_tensor)
diff <- (output$recon - data_tensor)$pow(2)
errors <- diff$mean(dim = 2)
})
as.numeric(errors)
}
diagnose_model_fit_v2 <- function(real_data, analysis_model,
p, k, n_rep = 1000,
latent_dim = 12, hidden_dim = 256,
epochs = 300, batch_size = 64,
lr = 1e-3, beta = 1.0,
val_ratio = 0.2, patience = 20,
alpha = 0.05) {
n <- nrow(real_data)
cat("============================================\n")
cat("  VAE-based Model Fit Diagnosis (v2)\n")
cat("============================================\n\n")
# ----------------------------------------------------------
# Step 1: 실제 데이터에 모형 적합
# ----------------------------------------------------------
cat("[Step 1] Fitting model to real data...\n")
fit <- cfa(analysis_model, data = real_data, ordered = TRUE, estimator = "WLSMV")
if (!lavInspect(fit, "converged")) stop("Model did not converge.")
traditional_fit <- fitMeasures(fit, c("chisq", "df", "pvalue",
"rmsea", "rmsea.ci.lower", "rmsea.ci.upper",
"cfi", "tli", "srmr"))
cat("  Traditional fit indices:\n")
print(round(traditional_fit, 4))
# ----------------------------------------------------------
# Step 2: 추정 모수 추출
# ----------------------------------------------------------
cat("\n[Step 2] Extracting estimated parameters...\n")
pop_info <- extract_pop_model(fit)
# ----------------------------------------------------------
# Step 3: 실제 데이터 잔차 계산
# ----------------------------------------------------------
cat("\n[Step 3] Computing real data residuals...\n")
pt <- parameterEstimates(fit)
thresh_pe  <- pt[pt$op == "|", ]
thresh_vec <- setNames(thresh_pe$est, paste0(thresh_pe$lhs, "|", thresh_pe$rhs))
implied_cor <- lavInspect(fit, "cor.ov")
real_model_result <- list(thresholds = thresh_vec, implied_cor = implied_cor)
real_residuals <- compute_cell_residuals_v2(real_data, real_model_result, p, k, n)
real_bmat <- assemble_block_matrix(real_residuals, p, k)
# ----------------------------------------------------------
# Step 4: Parametric bootstrap
# ----------------------------------------------------------
cat(sprintf("\n[Step 4] Generating %d bootstrap samples...\n", n_rep))
boot_matrices <- list()
success <- 0
for (r in 1:n_rep) {
if (r %% 500 == 0) cat(sprintf("  rep %d / %d\n", r, n_rep))
boot_dat <- tryCatch(
generate_cat_data_with_thresholds(pop_info$syntax, pop_info$thresholds, n),
error = function(e) NULL
)
if (is.null(boot_dat)) next
boot_fit <- tryCatch({
f <- cfa(analysis_model, data = boot_dat, ordered = TRUE, estimator = "WLSMV")
if (!lavInspect(f, "converged")) return(NULL)
f
}, error = function(e) NULL)
if (is.null(boot_fit)) next
boot_pe <- parameterEstimates(boot_fit)
boot_thresh_pe <- boot_pe[boot_pe$op == "|", ]
boot_thresh_vec <- setNames(boot_thresh_pe$est,
paste0(boot_thresh_pe$lhs, "|", boot_thresh_pe$rhs))
boot_implied_cor <- lavInspect(boot_fit, "cor.ov")
boot_result <- list(thresholds = boot_thresh_vec, implied_cor = boot_implied_cor)
boot_res <- tryCatch(
compute_cell_residuals_v2(boot_dat, boot_result, p, k, n),
error = function(e) NULL
)
if (is.null(boot_res)) next
success <- success + 1
boot_matrices[[success]] <- assemble_block_matrix(boot_res, p, k)
}
cat(sprintf("  %d / %d successful\n", success, n_rep))
boot_array <- array(unlist(boot_matrices), dim = c(p * k, p * k, success))
boot_array <- aperm(boot_array, c(3, 1, 2))
# ----------------------------------------------------------
# Step 5: VAE 훈련 (train/val split + early stopping)
# ----------------------------------------------------------
cat(sprintf("\n[Step 5] Training VAE...\n"))
vae_result <- train_vae_v2(
block_matrices_array = boot_array,
p = p, k = k,
latent_dim = latent_dim,
hidden_dim = hidden_dim,
epochs     = epochs,
batch_size = batch_size,
lr         = lr,
beta       = beta,
val_ratio  = val_ratio,
patience   = patience
)
# ----------------------------------------------------------
# Step 6: Reference distribution (VALIDATION SET ONLY)
# ----------------------------------------------------------
cat("\n[Step 6] Computing reference distribution (validation set)...\n")
val_array <- boot_array[vae_result$val_idx, , , drop = FALSE]
ref_errors <- compute_recon_error_v2(
vae_result$model, val_array, vae_result$norm_params
)
cutoff <- quantile(ref_errors, 1 - alpha)
# ----------------------------------------------------------
# Step 7: 실제 데이터 진단
# ----------------------------------------------------------
cat("\n[Step 7] Diagnosing...\n")
real_input <- array(real_bmat, dim = c(1, p * k, p * k))
real_error <- compute_recon_error_v2(
vae_result$model, real_input, vae_result$norm_params
)
p_value <- mean(ref_errors >= real_error)
# ----------------------------------------------------------
# Results
# ----------------------------------------------------------
cat("\n============================================\n")
cat("  DIAGNOSIS RESULTS (v2)\n")
cat("============================================\n\n")
cat("--- Traditional Fit Indices ---\n")
cat(sprintf("  Chi-square = %.2f (df = %d, p = %.4f)\n",
traditional_fit["chisq"], traditional_fit["df"], traditional_fit["pvalue"]))
cat(sprintf("  RMSEA = %.4f [%.4f, %.4f]\n",
traditional_fit["rmsea"], traditional_fit["rmsea.ci.lower"], traditional_fit["rmsea.ci.upper"]))
cat(sprintf("  CFI   = %.4f\n", traditional_fit["cfi"]))
cat(sprintf("  TLI   = %.4f\n", traditional_fit["tli"]))
cat(sprintf("  SRMR  = %.4f\n", traditional_fit["srmr"]))
cat("\n--- VAE-based Diagnosis ---\n")
cat(sprintf("  Reconstruction Error (real):  %.6f\n", real_error))
cat(sprintf("  Reference (validation set):   M = %.6f, SD = %.6f\n",
mean(ref_errors), sd(ref_errors)))
cat(sprintf("  Cutoff (%.0f%%):                 %.6f\n", (1 - alpha) * 100, cutoff))
cat(sprintf("  Empirical p-value:            %.4f\n", p_value))
cat(sprintf("  Verdict: %s\n",
ifelse(real_error > cutoff,
">>> MISFIT DETECTED <<<",
"No evidence of misfit")))
return(list(
traditional_fit = traditional_fit,
recon_error     = real_error,
ref_errors      = ref_errors,
cutoff          = cutoff,
p_value         = p_value,
misfit_flag     = real_error > cutoff,
vae_result      = vae_result,
real_bmat       = real_bmat
))
}
# ============================================================
# USAGE
# ============================================================
result <- diagnose_model_fit_v2(
real_data      = dat_cat,
analysis_model = my_model,
p = 10, k = 3,
n_rep      = 1000,    # 충분한 bootstrap
latent_dim = 12,
hidden_dim = 256,
epochs     = 300,
patience   = 20,      # early stopping
val_ratio  = 0.2,     # 20% validation
alpha      = 0.05
)
# 사용:
plots <- plot_diagnosis(result)
plots$error_dist
plots$residual_heatmap
library(MASS)
library(lavaan)
library(dplyr)
## ── 핵심 시뮬레이션 함수 ────────────────────────────────────
sim_mni <- function(
nrep      = 500,
N         = 500,
I         = 5L,          # items per time
TT        = 5L,          # time points
## Growth
mu_alpha  = 0,
mu_beta   = 0.5,
var_alpha = 1.0,
var_beta  = 0.2,
cov_ab    = 0.1,
psi       = 0.1,         # first-order factor disturbance variance
## Measurement (standardized loading)
lambda    = 0.7,
tau       = 0,
## MNI
mni_type  = c("none", "tau", "loading", "residual"),
mni_size  = c("none", "small", "large"),
seed      = 123
) {
mni_type <- match.arg(mni_type)
mni_size <- match.arg(mni_size)
## residual variance from standardized lambda
sigma_e2 <- 1 - lambda^2   # item-level residual variance
## ── MNI 크기 설정 ──────────────────────────────────────────
## d_tau:  absolute drift in intercept  (last time vs first)
## d_lam:  absolute drift in loading
## d_res:  multiplicative drift in residual variance (× at last time)
mni_p <- switch(mni_size,
none  = list(n_ni = 0L, d_tau = 0,    d_lam = 0,    d_res = 1.0),
small = list(n_ni = 1L, d_tau = 0.10, d_lam = 0.10, d_res = 1.3),
large = list(n_ni = 3L, d_tau = 0.30, d_lam = 0.30, d_res = 2.0)
)
noninv_items <- if (mni_p$n_ni > 0L) tail(seq_len(I), mni_p$n_ni) else integer(0)
## nonlinear drift schedule  (u^2: starts slow, accelerates)
t_idx   <- 0L:(TT - 1L)
u       <- t_idx / (TT - 1L)
drift_t <- u^2              # 0, .0625, .25, .5625, 1 for TT=5
## base parameter matrices  (I × TT)
tau_mat <- matrix(tau,    nrow = I, ncol = TT)
lam_mat <- matrix(lambda, nrow = I, ncol = TT)
res_mat <- matrix(sigma_e2, nrow = I, ncol = TT)   # residual variances
if (length(noninv_items) > 0L) {
if (mni_type == "tau") {
for (tt in seq_len(TT))
tau_mat[noninv_items, tt] <- tau + mni_p$d_tau * drift_t[tt]
} else if (mni_type == "loading") {
for (tt in seq_len(TT))
lam_mat[noninv_items, tt] <- lambda + mni_p$d_lam * drift_t[tt]
} else if (mni_type == "residual") {
scale_t <- 1 + (mni_p$d_res - 1) * drift_t   # 1 ~ d_res
for (tt in seq_len(TT))
res_mat[noninv_items, tt] <- sigma_e2 * scale_t[tt]
}
}
## ── lavaan 모형 정의 ────────────────────────────────────────
## (A) linear LGCM
lav_linear <- '
i =~ 1*time1 + 1*time2 + 1*time3 + 1*time4 + 1*time5
s =~ 0*time1 + 1*time2 + 2*time3 + 3*time4 + 4*time5
i ~~ (phi1)*i
s ~~ (phi2)*s
i ~~ (phi12)*s
i ~  (k1)*1
s ~  (k2)*1
'
## (B) free-basis LGCM (slope basis at t2~t4 freed)
## first=0, last=1 fix; interior freed
lav_free <- '
i =~ 1*time1 + 1*time2 + 1*time3 + 1*time4 + 1*time5
s =~ 0*time1 + b2*time2 + b3*time3 + b4*time4 + 1*time5
i ~~ (phi1)*i
s ~~ (phi2)*s
i ~~ (phi12)*s
i ~  (k1)*1
s ~  (k2)*1
'
## ── 생성 파라미터 (true values) ─────────────────────────────
phi_mtx <- matrix(c(var_alpha, cov_ab,
cov_ab,   var_beta), 2L, 2L)
## sum of loadings and intercepts at each time (for EC population)
s_t <- colSums(lam_mat)   # length TT
c_t <- colSums(tau_mat)
## ── 반복 루프 ────────────────────────────────────────────────
store <- vector("list", nrep)
for (rep in seq_len(nrep)) {
set.seed(seed + rep)
## (1) Growth factors
gf      <- MASS::mvrnorm(N, mu = c(mu_alpha, mu_beta), Sigma = phi_mtx)
alpha_i <- gf[, 1L]
beta_i  <- gf[, 2L]
## (2) First-order latent factors  η_t = α + β·t + ζ_t
eta_mat <- matrix(NA_real_, N, TT)
for (tt in seq_len(TT)) {
zeta <- rnorm(N, 0, sqrt(psi))
eta_mat[, tt] <- alpha_i + beta_i * t_idx[tt] + zeta
}
## (3) Item responses  y_it = τ_it + λ_it·η_t + ε_it
dat_mat <- matrix(NA_real_, N, I * TT)
for (ii in seq_len(I)) {
for (tt in seq_len(TT)) {
col_idx <- (tt - 1L) * I + ii
eps     <- rnorm(N, 0, sqrt(res_mat[ii, tt]))
dat_mat[, col_idx] <- tau_mat[ii, tt] + lam_mat[ii, tt] * eta_mat[, tt] + eps
}
}
## (4) Sum scores
dat_sum <- data.frame(
time1 = rowSums(dat_mat[,  1L: 5L]),
time2 = rowSums(dat_mat[,  6L:10L]),
time3 = rowSums(dat_mat[, 11L:15L]),
time4 = rowSums(dat_mat[, 16L:20L]),
time5 = rowSums(dat_mat[, 21L:25L])
)
## (5) Fit 두 모형
fit_lin  <- tryCatch(lavaan::growth(lav_linear, data = dat_sum),
error = function(e) NULL)
fit_free <- tryCatch(lavaan::growth(lav_free,   data = dat_sum),
error = function(e) NULL)
if (is.null(fit_lin)) {
store[[rep]] <- NULL
next
}
## fit indices (linear model)
fi <- tryCatch(
lavaan::fitMeasures(fit_lin,
c("chisq","df","pvalue","cfi","tli","rmsea","srmr","aic","bic")),
error = function(e) rep(NA_real_, 9L)
)
## slope estimate
pe_lin <- lavaan::parameterEstimates(fit_lin)
k2_est <- pe_lin[pe_lin$label == "k2", "est"]
if (length(k2_est) == 0L) k2_est <- NA_real_
## free-basis: estimated basis & AIC
aic_free <- tryCatch(lavaan::fitMeasures(fit_free, "aic"),
error = function(e) NA_real_)
pe_free  <- tryCatch(lavaan::parameterEstimates(fit_free), error = function(e) NULL)
b2 <- if (!is.null(pe_free)) pe_free[pe_free$label == "b2", "est"] else NA_real_
b3 <- if (!is.null(pe_free)) pe_free[pe_free$label == "b3", "est"] else NA_real_
b4 <- if (!is.null(pe_free)) pe_free[pe_free$label == "b4", "est"] else NA_real_
if (length(b2) == 0L) b2 <- NA_real_
if (length(b3) == 0L) b3 <- NA_real_
if (length(b4) == 0L) b4 <- NA_real_
## nonlinearity index: deviation from linear basis (0, .25, .5, .75, 1)
linear_ref <- c(0, .25, .5, .75, 1)
basis_est  <- c(0, b2, b3, b4, 1)
nl_index   <- sqrt(mean((basis_est - linear_ref)^2, na.rm = TRUE))
store[[rep]] <- data.frame(
chisq    = fi[1L],
df_      = fi[2L],
pchi     = fi[3L],
cfi      = fi[4L],
tli      = fi[5L],
rmsea    = fi[6L],
srmr     = fi[7L],
aic_lin  = fi[8L],
aic_free = aic_free,
k2_est   = k2_est,
b2       = b2,
b3       = b3,
b4       = b4,
nl_index = nl_index
)
}
raw <- do.call(rbind, Filter(Negate(is.null), store))
## ── EC population k2 (분석적으로 계산) ──────────────────────
## B'B 역행렬 × B' × diag(s_t) × B × k_gen
B <- cbind(1, t_idx)
D <- diag(s_t, nrow = TT)
BtB_inv <- solve(t(B) %*% B)
M <- BtB_inv %*% t(B) %*% D %*% B   # 2×2
G <- BtB_inv %*% t(B) %*% D          # 2×TT
theta_gen <- c(mu_alpha, mu_beta)
ec_means  <- as.numeric(M %*% theta_gen + BtB_inv %*% t(B) %*% c_t)
k2_ec     <- ec_means[2L]
## ── 요약 ─────────────────────────────────────────────────────
data.frame(
mni_type       = mni_type,
mni_size       = mni_size,
n_conv         = nrow(raw),
## chi-square reject rate (null = no misfit, H0 rejected = misfit detected)
chisq.reject   = mean(raw$pchi < 0.05, na.rm = TRUE),
chisq.m        = mean(raw$chisq,       na.rm = TRUE),
## CFI  (closer to 1 = better)
cfi.m          = mean(raw$cfi,         na.rm = TRUE),
cfi.below.95   = mean(raw$cfi < 0.95,  na.rm = TRUE),
## RMSEA  (> 0.05 = poor)
rmsea.m        = mean(raw$rmsea,       na.rm = TRUE),
rmsea.above05  = mean(raw$rmsea > 0.05, na.rm = TRUE),
## SRMR  (> 0.05 = poor)
srmr.m         = mean(raw$srmr,        na.rm = TRUE),
srmr.above05   = mean(raw$srmr > 0.05, na.rm = TRUE),
## Slope bias
k2_ec          = k2_ec,          # EC population (true target)
k2.m           = mean(raw$k2_est, na.rm = TRUE),
k2.bias        = mean(raw$k2_est - mu_beta, na.rm = TRUE),
k2.rbias       = mean((raw$k2_est - k2_ec) / k2_ec, na.rm = TRUE),
## Free-basis nonlinearity index
nl_index.m     = mean(raw$nl_index,    na.rm = TRUE),
nl_index.sd    = sd(raw$nl_index,      na.rm = TRUE),
## AIC: free-basis better than linear? (positive = free-basis wins)
aic_diff.m     = mean(raw$aic_lin - raw$aic_free, na.rm = TRUE),  # positive = free-basis better
aic_free_win   = mean((raw$aic_lin - raw$aic_free) > 2, na.rm = TRUE),
## Basis estimates (mean)
b2.m = mean(raw$b2, na.rm = TRUE),
b3.m = mean(raw$b3, na.rm = TRUE),
b4.m = mean(raw$b4, na.rm = TRUE)
)
}
## ══════════════════════════════════════════════════════════════
##  전체 조건 실행
## ══════════════════════════════════════════════════════════════
conditions <- tribble(
~mni_type,   ~mni_size,
"none",      "none",
"tau",       "small",
"tau",       "large",
"loading",   "small",
"loading",   "large",
"residual",  "small",
"residual",  "large"
)
cat("Running sensitivity simulation (nrep=500, N=500)...\n")
cat(sprintf("Start: %s\n\n", Sys.time()))
results_all <- purrr::map_dfr(seq_len(nrow(conditions)), function(i) {
cond <- conditions[i, ]
cat(sprintf("[%d/%d] mni_type=%-9s  mni_size=%-6s  ... ",
i, nrow(conditions), cond$mni_type, cond$mni_size))
flush.console()
t0 <- proc.time()
res <- sim_mni(
nrep     = 500,
N        = 500,
mni_type = cond$mni_type,
mni_size = cond$mni_size,
seed     = 123
)
cat(sprintf("done (%.1fs)\n", (proc.time() - t0)["elapsed"]))
res
})
cat(sprintf("\nFinished: %s\n\n", Sys.time()))
## [Table 1] Fit index 민감도
tbl_fit <- results_all |>
select(mni_type, mni_size,
chisq.reject, cfi.m, cfi.below.95,
rmsea.m, rmsea.above05,
srmr.m, srmr.above05) |>
mutate(across(where(is.numeric), \(x) round(x, 4)))
cat("── Table 1: Fit Index Sensitivity ──────────────────────────\n")
cat("(chisq.reject / cfi.below.95 / rmsea.above05 / srmr.above05 = proportion flagging misfit)\n\n")
print(tbl_fit, row.names = FALSE)
## [Table 2] 파라미터 왜곡 및 phantom nonlinearity 탐지
tbl_param <- results_all |>
select(mni_type, mni_size,
k2_ec, k2.m, k2.rbias,
nl_index.m, nl_index.sd,
aic_free_win,
b2.m, b3.m, b4.m) |>
mutate(across(where(is.numeric), \(x) round(x, 4)))
cat("\n── Table 2: Parameter Bias & Phantom Nonlinearity Detection ─\n")
cat("(aic_free_win = proportion of reps where free-basis AIC wins by >2)\n")
cat("(linear ref basis: b2=0.25, b3=0.50, b4=0.75)\n\n")
print(tbl_param, row.names = FALSE)
## ══════════════════════════════════════════════════════════════
##  시각화
## ══════════════════════════════════════════════════════════════
library(ggplot2)
library(tidyr)
## (A) Fit index reject rates 히트맵
tbl_heat <- results_all |>
select(mni_type, mni_size,
`Chi-sq\nreject`  = chisq.reject,
`CFI\n< .95`      = cfi.below.95,
`RMSEA\n> .05`    = rmsea.above05,
`SRMR\n> .05`     = srmr.above05) |>
pivot_longer(-c(mni_type, mni_size), names_to = "index", values_to = "rate") |>
mutate(
condition = paste0(mni_type, "\n(", mni_size, ")"),
condition = factor(condition, levels = unique(condition))
)
p_heat <- ggplot(tbl_heat, aes(x = index, y = condition, fill = rate)) +
geom_tile(color = "white", linewidth = .5) +
geom_text(aes(label = sprintf("%.2f", rate)), size = 3.5) +
scale_fill_gradient2(low = "#2166ac", mid = "#f7f7f7", high = "#d73027",
midpoint = .10, limits = c(0, 1),
name = "Rejection\nrate") +
labs(title = "Fit Index Sensitivity to MNI Type & Size",
subtitle = "Sum score 1-LGCM  |  N=500, nrep=500",
x = "Fit Index", y = "Condition") +
theme_minimal(base_size = 12) +
theme(panel.grid = element_blank())
## (B) Free-basis 추정치: phantom nonlinearity 시각화
basis_linear_ref <- data.frame(t_val = 0:4, basis = c(0, .25, .5, .75, 1),
mni_type = "Linear\n(ref)", mni_size = "")
tbl_basis <- results_all |>
select(mni_type, mni_size, b2.m, b3.m, b4.m) |>
mutate(
t0 = 0, t1 = b2.m, t2 = b3.m, t3 = b4.m, t4 = 1
) |>
pivot_longer(cols = starts_with("t"), names_to = "t_val", values_to = "basis") |>
mutate(t_val = as.integer(sub("t", "", t_val)),
label = paste0(mni_type, " / ", mni_size))
p_basis <- ggplot(tbl_basis, aes(x = t_val, y = basis,
color = mni_type, linetype = mni_size,
group = label)) +
geom_line(linewidth = .9) +
geom_point(size = 2) +
geom_abline(slope = .25, intercept = 0, linetype = "dotted",
color = "gray40", linewidth = .8) +
annotate("text", x = 4.05, y = 1, label = "linear\nref",
hjust = 0, size = 3, color = "gray40") +
scale_x_continuous(breaks = 0:4, labels = paste0("t", 1:5)) +
labs(title = "Free-Basis Slope Estimates under MNI",
subtitle = "Deviation from dotted line = phantom nonlinearity",
x = "Time", y = "Estimated basis weight",
color = "MNI type", linetype = "MNI size") +
theme_minimal(base_size = 12)
cat("\nPlots saved: fig1_fit_sensitivity.png  |  fig2_basis_phantom.png\n")
p_heat
p_basis
